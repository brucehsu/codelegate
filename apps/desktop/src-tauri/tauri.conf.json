{
  "productName": "Codelegate",
  "identifier": "com.codelegate.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm --filter @codelegate/desktop dev",
    "beforeBuildCommand": "pnpm --filter @codelegate/desktop build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codelegate",
        "width": 1000,
        "height": 700
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
